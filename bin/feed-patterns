#!/usr/bin/env bash
# =============================================================================
# feed-patterns — Primary pipeline: Java APIs → ggen template variables → patterns
#
# This is the primary mechanism for ggen's pattern-generator capability:
#
#   Java source → [Rust extractor] → ggen vars → [ggen sync] → generated patterns
#
# The Rust extractor reads dogfood pattern implementations, extracts their
# public API signatures (sealed hierarchies, record components, method signatures),
# and writes TOML variable files that ggen uses to regenerate patterns from templates.
#
# Usage:
#   bin/feed-patterns [--source <dir>] [--output <dir>] [--filter <pattern>] [--dry-run]
#
# Examples:
#   bin/feed-patterns                                # extract all patterns
#   bin/feed-patterns --filter "concurrency"         # only concurrency patterns
#   bin/feed-patterns --dry-run                      # show what would be generated
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
EXTRACTOR_DIR="$PROJECT_ROOT/tools/pattern-api-extractor"
EXTRACTOR_BIN="$EXTRACTOR_DIR/target/release/pattern-api-extractor"
SOURCE_DIR="$PROJECT_ROOT/src/main/java"
OUTPUT_DIR="$PROJECT_ROOT/.ggen_vars"
FILTER=""
DRY_RUN=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    cat <<'EOF'
feed-patterns — Feed Java pattern APIs to ggen

USAGE:
    bin/feed-patterns [options]

OPTIONS:
    --source <dir>     Source directory to scan (default: src/main/java)
    --output <dir>     Output directory for .toml var files (default: .ggen_vars)
    --filter <pattern> Only process files matching this pattern (e.g., "dogfood")
    --dry-run          Show what would be extracted without running
    --inspect          Show pattern type summary without extracting
    -h, --help         Show this help

PIPELINE:
    1. Build Rust extractor (cargo build --release)
    2. Walk source directory, extract pattern APIs
    3. Write .ggen_vars/<ClassName>.toml for each pattern
    4. For each .toml, you can invoke: bin/jgen generate -t <template> -n <Name> -p <pkg>

EXAMPLES:
    bin/feed-patterns
    bin/feed-patterns --filter "concurrency" --dry-run
    bin/feed-patterns --source src/main/java/org/acme/dogfood

EOF
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --source) SOURCE_DIR="$2"; shift 2 ;;
        --output) OUTPUT_DIR="$2"; shift 2 ;;
        --filter) FILTER="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        --inspect)
            build_extractor
            "$EXTRACTOR_BIN" inspect "$SOURCE_DIR"
            exit 0
            ;;
        -h|--help) usage; exit 0 ;;
        *) echo -e "${RED}Unknown option: $1${NC}"; usage; exit 1 ;;
    esac
done

build_extractor() {
    if [[ ! -f "$EXTRACTOR_BIN" ]] || [[ "$EXTRACTOR_DIR/src/main.rs" -nt "$EXTRACTOR_BIN" ]]; then
        echo -e "${BLUE}[1/3] Building Rust pattern-api-extractor...${NC}"
        cd "$EXTRACTOR_DIR"
        cargo build --release --quiet 2>&1 | tail -5
        echo -e "${GREEN}  ✓ Extractor built: $EXTRACTOR_BIN${NC}"
        cd "$PROJECT_ROOT"
    else
        echo -e "${GREEN}[1/3] Extractor up to date (skipping build)${NC}"
    fi
}

if $DRY_RUN; then
    echo -e "${YELLOW}[DRY RUN] Would extract from: $SOURCE_DIR${NC}"
    echo -e "${YELLOW}[DRY RUN] Would write vars to: $OUTPUT_DIR${NC}"
    if [[ -n "$FILTER" ]]; then
        echo -e "${YELLOW}[DRY RUN] Filter: $FILTER${NC}"
    fi
    java_count=$(find "$SOURCE_DIR" -name "*.java" 2>/dev/null | wc -l)
    echo -e "${YELLOW}[DRY RUN] Java files found: $java_count${NC}"
    echo ""
    echo "Run without --dry-run to execute the pipeline."
    exit 0
fi

echo -e "${BLUE}╔══════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║     Pattern API Extractor — ggen Feeding Pipeline     ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════════╝${NC}"
echo ""

# Step 1: Build extractor
build_extractor

# Step 2: Extract pattern APIs
echo ""
echo -e "${BLUE}[2/3] Extracting pattern APIs from Java source...${NC}"

FILTER_ARG=""
if [[ -n "$FILTER" ]]; then
    FILTER_ARG="--filter $FILTER"
    echo -e "  Filter: ${YELLOW}$FILTER${NC}"
fi

"$EXTRACTOR_BIN" generate-all "$SOURCE_DIR" --output-dir "$OUTPUT_DIR" $FILTER_ARG

# Step 3: Summary and next steps
echo ""
echo -e "${BLUE}[3/3] Pipeline complete${NC}"
TOML_COUNT=$(find "$OUTPUT_DIR" -name "*.toml" 2>/dev/null | wc -l)
echo -e "  ${GREEN}✓${NC} Generated ${TOML_COUNT} ggen variable files in $OUTPUT_DIR"
echo ""

echo -e "${YELLOW}Next steps — regenerate patterns from templates:${NC}"
echo ""

# Show sample jgen commands based on what was extracted
if [[ -d "$OUTPUT_DIR" ]]; then
    for toml_file in "$OUTPUT_DIR"/*.toml; do
        [[ -f "$toml_file" ]] || continue
        name=$(basename "$toml_file" .toml)

        # Detect template from class name
        template="core/record"
        case "$name" in
            *Gatherer*) template="core/gatherer" ;;
            *ScopedValue*) template="concurrency/scoped-value" ;;
            *StructuredTask*) template="concurrency/structured-task-scope" ;;
            *VirtualThread*) template="concurrency/virtual-thread" ;;
            *JavaTime*) template="api/java-time" ;;
            *String*Methods*) template="api/string-methods" ;;
            *Result*) template="error-handling/result-railway" ;;
            *Validation*) template="security/input-validation" ;;
            *Pattern*|*Matching*) template="core/pattern-matching-switch" ;;
        esac

        pkg=$(grep -m1 'package' "$toml_file" 2>/dev/null | sed 's/package = "//;s/"//' || echo "org.acme.dogfood")
        echo "  bin/jgen generate -t $template -n $name -p $pkg"
    done
fi

echo ""
echo -e "${GREEN}✓ Feed pipeline complete. Pattern APIs are ready for ggen generation.${NC}"
