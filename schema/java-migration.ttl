    jmig:hasSource "java.io.File, FileInputStream, FileOutputStream" ;
    jmig:hasTarget "api/nio2-files.tera" ;
    jmig:hasCategory "api" ;
    jmig:hasPriority 2 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java8> .

jmig:CollectionsUnmodifiableToFactory a jmig:MigrationRule ;
    rdfs:label "Collections.unmodifiable*() → factory methods" ;
    jmig:hasSource "Collections.unmodifiableList(), new ArrayList<>(Arrays.asList(...))" ;
    jmig:hasTarget "api/collection-factories.tera" ;
    jmig:hasCategory "api" ;
    jmig:hasPriority 2 ;
    jmig:isBreaking false ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java9> .

jmig:RuntimeExecToProcessBuilder a jmig:MigrationRule ;
    rdfs:label "Runtime.exec() → ProcessBuilder" ;
    jmig:hasSource "Runtime.getRuntime().exec(cmd)" ;
    jmig:hasTarget "api/process-builder.tera" ;
    jmig:hasCategory "api" ;
    jmig:hasPriority 3 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java9> .

jmig:LegacyCollectionsToModern a jmig:MigrationRule ;
    rdfs:label "Vector/Hashtable/Stack → modern collections" ;
    jmig:hasSource "java.util.Vector, Hashtable, Stack" ;
    jmig:hasTarget "api/collection-factories.tera" ;
    jmig:hasCategory "api" ;
    jmig:hasPriority 1 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java8> .

# =============================================================================
# Testing Migrations
# =============================================================================

jmig:JUnit3ToJUnit5 a jmig:MigrationRule ;
    rdfs:label "JUnit 3 → JUnit 5" ;
    jmig:hasSource "extends TestCase, test methods named testXxx" ;
    jmig:hasTarget "testing/junit5-test.tera" ;
    jmig:hasCategory "testing" ;
    jmig:hasPriority 1 ;
    jmig:isBreaking true .

jmig:JUnit4ToJUnit5 a jmig:MigrationRule ;
    rdfs:label "JUnit 4 → JUnit 5" ;
    jmig:hasSource "@org.junit.Test, @RunWith, @Rule" ;
    jmig:hasTarget "testing/junit5-test.tera" ;
    jmig:hasCategory "testing" ;
    jmig:hasPriority 1 ;
    jmig:isBreaking true .

jmig:AssertionsToAssertJ a jmig:MigrationRule ;
    rdfs:label "JUnit assertions → AssertJ" ;
    jmig:hasSource "assertEquals, assertTrue, assertNotNull" ;
    jmig:hasTarget "testing/assertj-assertions.tera" ;
    jmig:hasCategory "testing" ;
    jmig:hasPriority 2 ;
    jmig:isBreaking false .

# =============================================================================
# Build Migrations
# =============================================================================

jmig:JavaEEToJakarta a jmig:MigrationRule ;
    rdfs:label "javax.* → jakarta.*" ;
    jmig:hasSource "javax.servlet, javax.persistence, javax.annotation" ;
    jmig:hasTarget "security/jakarta-migration.tera" ;
    jmig:hasCategory "migration" ;
    jmig:hasPriority 1 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java17> .

