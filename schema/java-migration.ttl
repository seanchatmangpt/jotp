    jmig:hasSource "throws clause, try-catch with rethrow" ;
    jmig:hasTarget "error-handling/result-railway.tera" ;
    jmig:hasCategory "error-handling" ;
    jmig:hasPriority 2 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java17> .

jmig:NullReturnToOptional a jmig:MigrationRule ;
    rdfs:label "Null Returns → Optional<T>" ;
    jmig:hasSource "Methods returning null to indicate absence" ;
    jmig:hasTarget "error-handling/optional-result.tera" ;
    jmig:hasCategory "error-handling" ;
    jmig:hasPriority 1 ;
    jmig:isBreaking true ;
    jmig:hasTargetVersion <https://jgen.dev/ontology/java/core#Java8> .
