@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix java:  <https://jgen.dev/ontology/java#> .
@prefix jpat:  <https://jgen.dev/ontology/java/patterns#> .
@prefix eip:   <https://jgen.dev/ontology/java/messaging#> .

# =============================================================================
# Java Messaging Patterns Ontology (EIP)
# Enterprise Integration Patterns implemented with JOTP primitives
# =============================================================================

eip:Ontology a owl:Ontology ;
    rdfs:label "Java Messaging Patterns" ;
    rdfs:comment "Ontology of Enterprise Integration Patterns implemented with JOTP (Joe Armstrong / Erlang/OTP) primitives in Java 26" ;
    owl:versionInfo "1.0.0" ;
    owl:imports <https://jgen.dev/ontology/java/patterns#> .

# =============================================================================
# JOTP Primitives (Java 26 implementations of OTP concepts)
# =============================================================================

eip:JOTPPrimitive a owl:Class ;
    rdfs:label "JOTP Primitive" ;
    rdfs:comment "A Joe Armstrong / Erlang/OTP primitive implemented in Java 26" .

eip:Proc a eip:JOTPPrimitive ;
    rdfs:label "Proc" ;
    rdfs:comment "Lightweight process with virtual-thread mailbox and pure state handler (OTP: spawn/3)" .

eip:EventManager a eip:JOTPPrimitive ;
    rdfs:label "EventManager" ;
    rdfs:comment "Typed event manager with addHandler, notify, syncNotify (OTP: gen_event)" .

eip:Supervisor a eip:JOTPPrimitive ;
    rdfs:label "Supervisor" ;
    rdfs:comment "Supervision tree with ONE_FOR_ONE / ONE_FOR_ALL / REST_FOR_ONE strategies" .

eip:StateMachine a eip:JOTPPrimitive ;
    rdfs:label "StateMachine" ;
    rdfs:comment "gen_statem: state/event/data separation with sealed Transition hierarchy" .

eip:StructuredTaskScope a eip:JOTPPrimitive ;
    rdfs:label "StructuredTaskScope" ;
    rdfs:comment "Structured concurrency for parallel fan-out with fail-fast semantics" .

# =============================================================================
# Messaging Pattern Classification
# =============================================================================

eip:MessagingPattern a owl:Class ;
    rdfs:subClassOf jpat:Pattern ;
    rdfs:label "Messaging Pattern" ;
    rdfs:comment "Enterprise Integration Pattern for messaging systems" .

eip:FoundationPattern a owl:Class ;
    rdfs:subClassOf eip:MessagingPattern ;
    rdfs:label "Foundation Pattern" ;
    rdfs:comment "Core messaging patterns: Message Bus, Datatype Channel, Durable Subscriber, Service Activator, Idempotent Receiver" .

eip:RoutingPattern a owl:Class ;
    rdfs:subClassOf eip:MessagingPattern ;
    rdfs:label "Routing Pattern" ;
    rdfs:comment "Message routing patterns: Content-Based Router, Dead Letter Channel, Wire Tap, Routing Slip, Resequencer" .

eip:OrchestrationPattern a owl:Class ;
    rdfs:subClassOf eip:MessagingPattern ;
    rdfs:label "Orchestration Pattern" ;
    rdfs:comment "Process coordination patterns: Process Manager, Correlation Identifier, Scatter-Gather" .

eip:ResiliencePattern a owl:Class ;
    rdfs:subClassOf eip:MessagingPattern ;
    rdfs:label "Resilience Pattern" ;
    rdfs:comment "Fault tolerance patterns: Supervision Storm, Control Bus" .

# =============================================================================
# Pattern Properties
# =============================================================================

eip:mapsToPrimitive a owl:ObjectProperty ;
    rdfs:domain eip:MessagingPattern ;
    rdfs:range eip:JOTPPrimitive ;
    rdfs:label "maps to JOTP primitive" ;
    rdfs:comment "The JOTP primitive that implements this pattern" .

eip:hasComplexity a owl:DatatypeProperty ;
    rdfs:domain eip:MessagingPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "complexity level" ;
    rdfs:comment "Implementation complexity (1=simple, 2=moderate, 3=complex)" .

eip:requiresPattern a owl:ObjectProperty ;
    rdfs:domain eip:MessagingPattern ;
    rdfs:range eip:MessagingPattern ;
    rdfs:label "requires pattern" ;
    rdfs:comment "A pattern that must be present for this pattern to work" .

eip:generatesMessageType a owl:ObjectProperty ;
    rdfs:domain eip:MessagingPattern ;
    rdfs:range java:Type ;
    rdfs:label "generates message type" ;
    rdfs:comment "The message type generated by this pattern" .

# =============================================================================
# FOUNDATION PATTERNS
# =============================================================================

eip:MessageBus a eip:FoundationPattern ;
    rdfs:label "Message Bus" ;
    jpat:hasTemplate "messaging/message-bus.tera" ;
    eip:mapsToPrimitive eip:EventManager ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Centralized message distribution to multiple subscribers via EventManager" ;
    jpat:replacesLegacy "Custom pub-sub implementations, JMS Topics" .

eip:DatatypeChannel a eip:FoundationPattern ;
    rdfs:label "Datatype Channel" ;
    jpat:hasTemplate "messaging/datatype-channel.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Dedicated channel for each data type with type-safe message handling" ;
    jpat:replacesLegacy "Object channels with runtime type checking" .

eip:DurableSubscriber a eip:FoundationPattern ;
    rdfs:label "Durable Subscriber" ;
    jpat:hasTemplate "messaging/durable-subscriber.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Subscriber that receives messages sent while inactive, with persistent state" ;
    jpat:replacesLegacy "JMS durable subscribers, persistent queues" .

eip:ServiceActivator a eip:FoundationPattern ;
    rdfs:label "Service Activator" ;
    jpat:hasTemplate "messaging/service-activator.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Invoke service method upon message receipt with mailbox-based activation" ;
    jpat:replacesLegacy "Message-driven beans, Spring @ServiceActivator" .

eip:IdempotentReceiver a eip:FoundationPattern ;
    rdfs:label "Idempotent Receiver" ;
    jpat:hasTemplate "messaging/idempotent-receiver.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Track processed messages to handle duplicates safely with nanosecond timestamps" ;
    jpat:replacesLegacy "Database deduplication, Redis idempotency keys" .

eip:CanonicalMessage a eip:FoundationPattern ;
    rdfs:label "Canonical Message" ;
    jpat:hasTemplate "messaging/canonical-message.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Standardized message format using sealed interface hierarchy for exhaustive pattern matching" ;
    jpat:replacesLegacy "Generic Map messages, untyped JSON payloads" .

eip:PublishSubscribe a eip:FoundationPattern ;
    rdfs:label "Publish-Subscribe" ;
    jpat:hasTemplate "messaging/pub-sub.tera" ;
    eip:mapsToPrimitive eip:EventManager ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Broadcast messages to multiple subscribers with EventManager" ;
    jpat:replacesLegacy "Observer pattern with explicit listener management" .

# =============================================================================
# ROUTING PATTERNS
# =============================================================================

eip:ContentBasedRouter a eip:RoutingPattern ;
    rdfs:label "Content-Based Router" ;
    jpat:hasTemplate "messaging/content-based-router.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Route messages based on content using pattern matching switch" ;
    jpat:replacesLegacy "Chain of if-else statements, rule engines" .

eip:DeadLetterChannel a eip:RoutingPattern ;
    rdfs:label "Dead Letter Channel" ;
    jpat:hasTemplate "messaging/dead-letter-channel.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Handle failed messages with dedicated error channel and logging" ;
    jpat:replacesLegacy "Silent message loss, catch-and-log patterns" .

eip:WireTap a eip:RoutingPattern ;
    rdfs:label "Wire Tap" ;
    jpat:hasTemplate "messaging/wire-tap.tera" ;
    eip:mapsToPrimitive eip:EventManager ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Non-intrusive message observation without affecting main flow" ;
    jpat:replacesLegacy "Logging interceptors, AOP-based monitoring" .

eip:RoutingSlip a eip:RoutingPattern ;
    rdfs:label "Routing Slip" ;
    jpat:hasTemplate "messaging/routing-slip.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Message carries its processing steps for dynamic routing" ;
    jpat:replacesLegacy "Workflow engines, BPMN processes" .

eip:Resequencer a eip:RoutingPattern ;
    rdfs:label "Resequencer" ;
    jpat:hasTemplate "messaging/resequencer.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Reorder out-of-sequence messages using timestamps with gap detection" ;
    jpat:replacesLegacy "Custom sorting, sequence number management" .

# =============================================================================
# ORCHESTRATION PATTERNS
# =============================================================================

eip:ProcessManager a eip:OrchestrationPattern ;
    rdfs:label "Process Manager" ;
    jpat:hasTemplate "messaging/process-manager.tera" ;
    eip:mapsToPrimitive eip:StateMachine ;
    eip:hasComplexity 3 ;
    jpat:hasIntent "Coordinate complex message flows with state machine-based saga management" ;
    jpat:replacesLegacy "BPM engines, orchestration frameworks" .

eip:CorrelationIdentifier a eip:OrchestrationPattern ;
    rdfs:label "Correlation Identifier" ;
    jpat:hasTemplate "messaging/correlation-identifier.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Track related messages across the system using UUID correlation IDs" ;
    jpat:replacesLegacy "Custom correlation maps, conversation IDs" .

eip:ScatterGather a eip:OrchestrationPattern ;
    rdfs:label "Scatter-Gather" ;
    jpat:hasTemplate "messaging/scatter-gather.tera" ;
    eip:mapsToPrimitive eip:StructuredTaskScope ;
    eip:hasComplexity 3 ;
    jpat:hasIntent "Broadcast to multiple processors and aggregate results with structured concurrency" ;
    jpat:replacesLegacy "CompletableFuture.allOf, CountDownLatch patterns" .

# =============================================================================
# RESILIENCE PATTERNS
# =============================================================================

eip:SupervisionStorm a eip:ResiliencePattern ;
    rdfs:label "Supervision Storm" ;
    jpat:hasTemplate "messaging/supervision-storm.tera" ;
    eip:mapsToPrimitive eip:Supervisor ;
    eip:hasComplexity 3 ;
    jpat:hasIntent "Supervise process tree with restart strategies and cascade control" ;
    jpat:replacesLegacy "Try-catch chains, circuit breaker patterns alone" .

eip:ControlBus a eip:ResiliencePattern ;
    rdfs:label "Control Bus" ;
    jpat:hasTemplate "messaging/control-bus.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 2 ;
    jpat:hasIntent "Manage and monitor messaging system via ProcSys introspection" ;
    jpat:replacesLegacy "JMX beans, custom admin endpoints" .

# =============================================================================
# DOMAIN TYPES (Supporting Types)
# =============================================================================

eip:DomainTypes a eip:MessagingPattern ;
    rdfs:label "Domain Types" ;
    jpat:hasTemplate "messaging/domain-types.tera" ;
    eip:mapsToPrimitive eip:Proc ;
    eip:hasComplexity 1 ;
    jpat:hasIntent "Generate sealed interface message types and record payloads for type-safe messaging" ;
    jpat:replacesLegacy "POJO messages, untyped event objects" .

# =============================================================================
# PATTERN DEPENDENCIES
# =============================================================================

eip:ScatterGather eip:requiresPattern eip:CorrelationIdentifier .
eip:ProcessManager eip:requiresPattern eip:CorrelationIdentifier .
eip:SupervisionStorm eip:requiresPattern eip:DeadLetterChannel .
eip:RoutingSlip eip:requiresPattern eip:CanonicalMessage .
