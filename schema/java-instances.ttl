@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix java:  <https://jgen.dev/ontology/java#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix inst:  <https://jgen.dev/instance/> .

# =============================================================================
# java-instances.ttl
# Declares the concrete Java types to be generated by ggen sync.
# Add/remove instances here to control what files are generated.
# =============================================================================

# ── Extra class declarations (not in schema imports) ──────────────────────────

java:Service  a owl:Class ; rdfs:label "Service"  ; rdfs:comment "Application service interface." .
java:Testable a owl:Class ; rdfs:label "Testable"  ; rdfs:comment "Type that has a generated JUnit 5 test class." .

# ── Records ───────────────────────────────────────────────────────────────────

inst:Address a java:Record ;
    java:hasName    "Address" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "Value type representing a postal address." .

inst:Person a java:Record ;
    java:hasName    "Person" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "Value type representing a person entity." .

inst:Money a java:Record ;
    java:hasName    "Money" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "Immutable monetary amount with currency." .

inst:OrderItem a java:Record ;
    java:hasName    "OrderItem" ;
    java:hasPackage "org.acme.order" ;
    rdfs:comment    "A single line in a customer order." .

# ── Sealed interfaces ─────────────────────────────────────────────────────────

inst:PaymentStatus a java:SealedInterface ;
    java:hasName    "PaymentStatus" ;
    java:hasPackage "org.acme.order" ;
    rdfs:comment    "Discriminated union of payment lifecycle states." .

inst:Result a java:SealedInterface ;
    java:hasName    "Result" ;
    java:hasPackage "org.acme.util" ;
    rdfs:comment    "Railway-oriented Result<T,E> sealed type." .

# ── Services ──────────────────────────────────────────────────────────────────

inst:PersonDomain a java:Service ;
    java:hasName    "Person" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "Business logic for Person management." .

inst:OrderDomain a java:Service ;
    java:hasName    "Order" ;
    java:hasPackage "org.acme.order" ;
    rdfs:comment    "Business logic for Order processing." .

# ── Testable types (records + services get tests) ─────────────────────────────

inst:PersonTestable a java:Testable ;
    java:hasName    "Person" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "JUnit 5 test suite for Person." .

inst:AddressTestable a java:Testable ;
    java:hasName    "Address" ;
    java:hasPackage "org.acme.demo" ;
    rdfs:comment    "JUnit 5 test suite for Address." .

inst:PaymentStatusTestable a java:Testable ;
    java:hasName    "PaymentStatus" ;
    java:hasPackage "org.acme.order" ;
    rdfs:comment    "JUnit 5 test suite for PaymentStatus." .
