{
  "variables": {
    "java_version": "26",
    "java_build": "33",
    "mvnd_version": "2.0.0-rc-3",
    "maven_version": "4.0.0-rc-3",
    "image_name": "jotp-java26-base",
    "image_tag": "latest"
  },
  "builders": [
    {
      "type": "docker",
      "image": "ubuntu:24.04",
      "commit": true,
      "changes": [
        "ENV JAVA_HOME=/opt/java",
        "ENV MAVEN_HOME=/opt/maven",
        "ENV MVND_HOME=/opt/mvnd",
        "ENV PATH=/opt/java/bin:/opt/maven/bin:/opt/mvnd/bin:/usr/local/bin:/usr/bin:/bin",
        "WORKDIR /app"
      ]
    }
  ],
  "provisioners": [
    {
      "type": "shell",
      "inline": [
        "apt-get update && apt-get install -y --no-install-recommends curl tar gzip wget ca-certificates bash git jq procps"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "echo 'Installing Java 26 EA Build ${self.variables.java_build}'",
        "mkdir -p /opt/java",
        "curl -fsSL \"https://download.java.net/java/early_access/jdk${self.variables.java_version}/${self.variables.java_build}/GPL/openjdk-${self.variables.java_version}-ea+${self.variables.java_build}_linux-x64_bin.tar.gz\" | tar -xzf - -C /opt/java --strip-components=1",
        "java --version"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "echo 'Installing Maven Daemon ${self.variables.mvnd_version}'",
        "mkdir -p /opt/mvnd",
        "curl -fsSL \"https://github.com/apache/maven-mvnd/releases/download/${self.variables.mvnd_version}/maven-mvnd-${self.variables.mvnd_version}-linux-amd64.tar.gz\" | tar -xzf - -C /opt/mvnd --strip-components=1",
        "ln -s /opt/mvnd/bin/mvnd /usr/local/bin/mvnd",
        "ln -s /opt/mvnd/bin/mvnd /usr/local/bin/mvn",
        "ln -s /opt/mvnd/bin/mvnw /usr/local/bin/mvnw",
        "mvnd --version"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "echo 'Installing Maven 4 ${self.variables.maven_version}'",
        "mkdir -p /opt/maven",
        "curl -fsSL \"https://archive.apache.org/dist/maven/maven-${/self.variables.maven_version}/binaries/apache-maven-${self.variables.maven_version}-bin.tar.gz\" | tar -xzf - -C /opt/maven --strip-components=1",
        "echo 'Maven 4 installation completed (Maven Daemon is primary)'"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "echo 'Setting up environment for JOTP'",
        "mkdir -p /app /root/.m2/repository /root/.m2/mvnd",
        "echo 'export JAVA_HOME=/opt/java' > /etc/profile.d/java.sh",
        "echo 'export MAVEN_HOME=/opt/maven' >> /etc/profile.d/java.sh",
        "echo 'export MVND_HOME=/opt/mvnd' >> /etc/profile.d/java.sh",
        "echo 'export PATH=/opt/java/bin:/opt/maven/bin:/opt/mvnd/bin:$PATH' >> /etc/profile.d/java.sh",
        "chmod +x /etc/profile.d/java.sh",
        "echo 'Packer image build complete!'"
      ]
    }
  ],
  "post-processors": [
    {
      "type": "docker-tag",
      "repository": "local/${self.variables.image_name}",
      "tag": "${self.variables.image_tag}"
    }
  ]
}