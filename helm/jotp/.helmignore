# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Documentation files (not needed in package)
README.md
INSTALL.md
QUICKSTART.md
FEATURES.md
DELIVERABLES.md
DEPLOYMENT-SUMMARY.md
# Scripts (not needed in package)
scripts/
# Examples (not needed in package)
examples/
