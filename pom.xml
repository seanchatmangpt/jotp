            <!-- <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-source-plugin</artifactId>
                <version>3.3.1</version>
                <executions>
                    <execution>
                        <id>attach-sources</id>
                        <goals>
                            <goal>jar-no-fork</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin> -->
            <!-- <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-gpg-plugin</artifactId>
                <version>3.2.4</version>
                <executions>
                    <execution>
                        <id>sign-artifacts</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>sign</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <keyname>${gpg.keyname}</keyname>
                    <passphraseServerId>gpg.passphrase</passphraseServerId>
                </configuration>
            </plugin> -->
        </plugins>
    </build>
    <profiles>
        <profile>
            <id>shade</id>
            <activation>
                <property>
                    <name>shade</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-shade-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <execution>
                                <phase>package</phase>
                                <goals>
                                    <goal>shade</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>dogfood</id>
            <activation>
                <property>
                    <name>dogfood</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.5.0</version>
                        <executions>
                            <execution>
                                <id>dogfood-check</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>${project.basedir}/bin/dogfood</executable>
                                    <arguments>
                                        <argument>generate</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>dogfood-report</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>${project.basedir}/bin/dogfood</executable>
                                    <arguments>
                                        <argument>report</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>benchmark</id>
            <activation>
                <property>
                    <name>benchmark</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.5.0</version>
                        <executions>
                            <execution>
                                <id>run-benchmarks</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>java</goal>
                                </goals>
                                <configuration>
                                    <mainClass>io.github.seanchatmangpt.jotp.benchmark.PatternBenchmarkSuite</mainClass>
                                    <classpathScope>test</classpathScope>
                                    <arguments>
                                        <argument>-f</argument>
                                        <argument>1</argument>
                                        <argument>-wi</argument>
                                        <argument>3</argument>
                                        <argument>-i</argument>
                                        <argument>5</argument>
                                        <argument>-rff</argument>
                                        <argument>${project.build.directory}/benchmark-results.json</argument>
                                        <argument>-rf</argument>
                                        <argument>json</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <!-- Archive Profiles: Organize 82 excluded tests by maturity/type -->
        <!-- These profiles allow selective test execution without pom.xml excludes -->

        <!-- PROFILE: core (default) - production-ready core tests only (113 tests) -->
        <profile>
            <id>core</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <!-- Default behavior: tests in src/test/java run automatically -->
        </profile>

        <!-- PROFILE: archive-infra - include test infrastructure (32 additional tests) -->
        <profile>
            <id>archive-infra</id>
            <activation>
                <property>
                    <name>archive-infra</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <testSourceDirectory>src/test/java:src/test-archive/test-infrastructure</testSourceDirectory>
                            <argLine>--enable-preview --add-reads io.github.seanchatmangpt.jotp=ALL-UNNAMED</argLine>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- PROFILE: archive-experimental - include v2.0 experimental features (62 additional tests) -->
        <profile>
            <id>archive-experimental</id>
            <activation>
                <property>
                    <name>archive-experimental</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <testSourceDirectory>src/test/java:src/test-archive/experimental</testSourceDirectory>
                            <argLine>--enable-preview --add-reads io.github.seanchatmangpt.jotp=ALL-UNNAMED</argLine>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- PROFILE: archive-stress - include performance/stress tests (27 additional tests) -->
        <profile>
            <id>archive-stress</id>
            <activation>
                <property>
                    <name>archive-stress</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <testSourceDirectory>src/test/java:src/test-archive/performance</testSourceDirectory>
                            <timeout>120000</timeout>
                            <argLine>--enable-preview --add-reads io.github.seanchatmangpt.jotp=ALL-UNNAMED</argLine>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- PROFILE: archive-all - run all 160 tests (core + infrastructure + experimental + stress) -->
        <profile>
            <id>archive-all</id>
            <activation>
                <property>
                    <name>archive-all</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <testSourceDirectory>src/test/java:src/test-archive</testSourceDirectory>
                            <timeout>120000</timeout>
                            <argLine>--enable-preview --add-reads io.github.seanchatmangpt.jotp=ALL-UNNAMED</argLine>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- PROFILE: archive-broken - only broken/malformed tests (for debugging) -->
        <profile>
            <id>archive-broken</id>
            <activation>
                <property>
                    <name>archive-broken</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <testSourceDirectory>src/test-archive/broken</testSourceDirectory>
                            <argLine>--enable-preview --add-reads io.github.seanchatmangpt.jotp=ALL-UNNAMED</argLine>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <distributionManagement>
        <snapshotRepository>
            <id>ossrh</id>
            <url>https://s01.oss.sonatype.org/content/repositories/snapshots</url>
        </snapshotRepository>
        <repository>
            <id>ossrh</id>
            <url>https://s01.oss.sonatype.org/service/local/staging/deploy/maven2/</url>
        </repository>
    </distributionManagement>
</project>
