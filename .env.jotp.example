# JOTP Docker Compose Environment Variables
# Copy this file to .env.jotp and customize for your environment
#
# Usage:
#   cp .env.jotp.example .env.jotp
#   # Edit .env.jotp with your settings
#   docker-compose -f docker-compose-jotp-cluster.yml --env-file .env.jotp up -d

# ── Application Configuration ─────────────────────────────────────────────────────
VERSION=1.0.0-SNAPSHOT
LOG_LEVEL=INFO

# ── JVM Settings ───────────────────────────────────────────────────────────────────
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XshowSettings:vm -XX:+UnlockExperimentalVMOptions -XX:+UseZGC -Xlog:gc*:file=/app/logs/gc.log:time,uptime,level,tags

# JVM Memory Settings
JVM_HEAP_MIN=256m
JVM_HEAP_MAX=2g
JVM_METASPACE_SIZE=256m
JVM_METASPACE_MAX=512m

# JIT Compilation
JVM_CI_COMPILER=server
JVM_TIERED_COMPILATION=true

# ── Node Configuration ─────────────────────────────────────────────────────────────
# Node identification
JOTP_NODE_PREFIX=jotp-node
JOTP_CLUSTER_NAME=jotp-cluster
JOTP_CLUSTER_MODE=distributed

# Peer discovery
JOTP_DISCOVERY_MODE=static
JOTP_PEER_SEEDS=jotp-node-2:50051,jotp-node-3:50051
JOTP_SEED_NODES=3

# Cluster coordination
JOTP_LEADER_ELECTION_ENABLED=true
JOTP_LEADER_ELECTION_TIMEOUT=30s
JOTP_HEARTBEAT_INTERVAL=5s
JOTP_PEER_FAILURE_DETECTION=30s
JOTP_NETWORK_PARTITION_DETECTION=60s

# Process configuration
JOTP_MAILBOX_SIZE=10000
JOTP_PROCESS_REGISTRY=distributed
JOTP_SUPERVISION_DEPTH=5
JOTP_MAX_PROCESSES=1000000

# ── gRPC Configuration ─────────────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_MAX_MESSAGE_SIZE=10485760  # 10MB
GRPC_KEEPALIVE_TIME=30s
GRPC_KEEPALIVE_TIMEOUT=10s
GRPC_PERMIT_KEEPALIVE_WITHOUT_STREAMS=true

# ── HTTP API Configuration ─────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_MANAGEMENT_PORT=9090
HTTP_MAX_THREADS=200
HTTP_MIN_THREADS=10

# ── Database Configuration ─────────────────────────────────────────────────────────
POSTGRES_DB=jotp_cluster
POSTGRES_USER=jotp
POSTGRES_PASSWORD=jotp_cluster_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MIN_CONNECTIONS=10
POSTGRES_CONNECTION_TIMEOUT=30s
POSTGRES_IDLE_TIMEOUT=10m

# PostgreSQL Pool Settings
POSTGRES_POOL_MAX_SIZE=100
POSTGRES_POOL_MIN_IDLE=10
POSTGRES_POOL_IDLE_TIMEOUT=600000
POSTGRES_POOL_MAX_LIFETIME=1800000

# ── Redis Configuration ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5s
REDIS_CLUSTER_MODE=false

# ── Messaging Configuration ───────────────────────────────────────────────────────
# NATS Configuration
NATS_URL=nats://nats:4222
NATS_SUBJECT_PREFIX=jotp
NATS_QUEUE_GROUP=jotp-cluster
NATS_MAX_RECONNECTS=-1
NATS_RECONNECT_WAIT=2s
NATS_TIMEOUT=10s

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=jotp-node
KAFKA_GROUP_ID=jotp-cluster
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SESSION_TIMEOUT=30000
KAFKA_HEARTBEAT_INTERVAL=10000

# ── Observability Configuration ───────────────────────────────────────────────────
# Metrics
JOTP_METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_PROMETHEUS_ENABLED=true
METRICS_EXPORT_INTERVAL=30s

# Tracing
JOTP_TRACING_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=jotp-node
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_BATCH_TIMEOUT=5s
OTEL_MAX_QUEUE_SIZE=2048
OTEL_MAX_EXPORT_BATCH_SIZE=512

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO
LOG_OUTPUT=/app/logs/jotp.log
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10
LOG_RETENTION_DAYS=30

# ── Grafana Configuration ──────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SERVER_ROOT_URL=http://localhost:3000
GRAFANA_INSTALL_PLUGINS=grafana-piechart-panel,grafana-worldmap-panel

# ── Monitoring Configuration ───────────────────────────────────────────────────────
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# AlertManager
ALERTMANAGER_ENABLED=true
ALERTMANAGER_URL=http://alertmanager:9093
ALERTMANAGER_RESOLVE_TIMEOUT=5m

# ── Health Check Configuration ────────────────────────────────────────────────────
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=30s

# Readiness probe
HEALTH_READINESS_ENABLED=true
HEALTH_READINESS_PATH=/health/ready
HEALTH_READINESS_INITIAL_DELAY=30s

# Liveness probe
HEALTH_LIVENESS_ENABLED=true
HEALTH_LIVENESS_PATH=/health/live
HEALTH_LIVENESS_INITIAL_DELAY=60s

# ── Performance Tuning ────────────────────────────────────────────────────────────
# Virtual Thread Configuration
VIRTUAL_THREADS_ENABLED=true
VIRTUAL_THREAD_POOL_SIZE=10000

# Process Registry
REGISTRY_CACHE_SIZE=10000
REGISTRY_CACHE_TTL=300s

# Mailbox Configuration
MAILBOX_CAPACITY=10000
MAILBOX_TIMEOUT=5s
MAILBOX_RETRY_COUNT=3

# ── Security Configuration ─────────────────────────────────────────────────────────
TLS_ENABLED=false
TLS_KEY_STORE_PATH=
TLS_KEY_STORE_PASSWORD=
TLS_TRUST_STORE_PATH=
TLS_TRUST_STORE_PASSWORD=

# Authentication
AUTH_ENABLED=false
AUTH_PROVIDER=none
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRATION=3600

# ── Development Configuration ─────────────────────────────────────────────────────
DEV_MODE=false
DEBUG_ENABLED=false
DEBUG_PORT=5005
HOT_RELOAD_ENABLED=false
SOURCE_MOUNT_ENABLED=false

# ── Resource Limits ───────────────────────────────────────────────────────────────
# CPU limits (in cores)
CPU_LIMIT=2
CPU_RESERVATION=0.5

# Memory limits
MEMORY_LIMIT=2g
MEMORY_RESERVATION=512m

# ── Docker Compose Options ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=jotp
COMPOSE_PARALLEL_LIMIT=4
COMPOSE_TIMEOUT=300
COMPOSE_REMOVE_ORPHANS=true

# ── Network Configuration ─────────────────────────────────────────────────────────
NETWORK_SUBNET=172.28.0.0/16
NETWORK_GATEWAY=172.28.0.1

# ── Volume Configuration ───────────────────────────────────────────────────────────
VOLUME_DRIVER=local
VOLUME_OPTS=
