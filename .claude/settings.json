{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAVEN_OPTS": "-Xmx2g -Xms512m"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(mvnd *)",
      "Bash(mvn *)",
      "Bash(./mvnw *)",
      "Bash(./bin/mvndw *)",
      "Bash(make *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(./bin/dogfood *)",
      "Bash(./bin/jgen *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(rm -rf *)",
      "Bash(sudo rm*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
