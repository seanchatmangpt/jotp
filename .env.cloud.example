# Cloud Provider Configuration
# Copy to .env.cloud and customize

# ── Provider Selection ───────────────────────────────────────────────────────
# Default: oci (Oracle Cloud Infrastructure - Always Free)
# Options: oci, aws, azure, gcp, ibm, openshift
CLOUD_PROVIDER=oci

# ── OCI (Oracle Cloud) Configuration ─────────────────────────────────────────
# These are used by Packer and Terraform

# Your OCI Tenancy OCID
OCI_TENANCY_OCID=

# Your OCI User OCID
OCI_USER_OCID=

# API Key Fingerprint (from OCI Console)
OCI_FINGERPRINT=

# Path to your API private key
OCI_PRIVATE_KEY_PATH=~/.oci/oci_api_key.pem

# OCI Region (default: us-phoenix-1)
OCI_REGION=us-phoenix-1

# Compartment OCID for resources
OCI_COMPARTMENT_OCID=

# Subnet OCID (for Packer builds)
OCI_SUBNET_OCID=

# Base Image OCID (Oracle Linux 8 for your region)
# Find with: oci compute image list --compartment-id <compartment-ocid>
OCI_BASE_IMAGE_OCID=

# Instance Shape (Always Free: VM.Standard.A1.Flex)
OCI_SHAPE=VM.Standard.A1.Flex

# Always Free tier limits:
# - 4 Arm Ampere A1 cores + 24GB RAM (recommended)
# - OR 2 AMD Compute VMs (1/8 OCPU, 1GB RAM each)
OCI_OCPUS=4
OCI_MEMORY_IN_GBS=24

# SSH Public Key (for instance access)
OCI_SSH_PUBLIC_KEY=~/.ssh/id_rsa.pub

# ── Application Configuration ────────────────────────────────────────────────
APP_NAME=java-maven-template
APP_VERSION=1.0.0-SNAPSHOT
APP_PORT=8080

# ── Alternative Providers (uncomment to use) ──────────────────────────────────

# AWS Configuration
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Azure Configuration
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_SUBSCRIPTION_ID=
# ARM_TENANT_ID=
# AZURE_REGION=eastus

# GCP Configuration
# GOOGLE_CREDENTIALS=~/.config/gcloud/application_default_credentials.json
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
