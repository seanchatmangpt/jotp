# ============================================================================
# JOTP Development Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment
# Note: .env is in .gitignore and should NOT be committed
#
# Usage:
#   cp .env.example .env
#   source .env
#   docker-compose up -d
# ============================================================================

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_DB=jotp
POSTGRES_USER=jotp
POSTGRES_PASSWORD=jotp_secret
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# PostgreSQL Performance Tuning
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ============================================================================
# Maven Repository Proxy Configuration
# ============================================================================

# Proxy Host and Port
MAVEN_PROXY_HOST=localhost
MAVEN_PROXY_PORT=8081

# Nexus Repository Configuration
NEXUS_ADMIN_USERNAME=admin
NEXUS_ADMIN_PASSWORD=admin123
NEXUS_MEMORY_MIN=1g
NEXUS_MEMORY_MAX=2g

# Artifactory Configuration (alternative to Nexus)
ARTIFACTORY_ADMIN_USERNAME=admin
ARTIFACTORY_ADMIN_PASSWORD=password
ARTIFACTORY_MEMORY_MIN=512m
ARTIFACTORY_MEMORY_MAX=1g

# ============================================================================
# Application Configuration
# ============================================================================

# Java/Maven Configuration
JAVA_VERSION=26
MAVEN_VERSION=4.0.0
MAVEN_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# Spring Boot Configuration (if used)
SPRING_PROFILES_ACTIVE=dev
LOG_LEVEL=INFO

# ============================================================================
# Docker Configuration
# ============================================================================

# Image version/tag
VERSION=latest

# Network configuration
DOCKER_NETWORK=jotp-network

# ============================================================================
# Build Configuration
# ============================================================================

# Maven Build Options
MVND_OPTS=-T1C
MAVEN_BUILD_THREADS=1C

# JVM Options for Build
BUILD_JAVA_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ============================================================================
# Development Tools Configuration
# ============================================================================

# Code Quality Tools
SPOTLESS_FORMAT=true
ARCHUNIT_CHECK=true

# Test Configuration
TEST_PROFILE=unit
TEST_TIMEOUT=300

# ============================================================================
# Monitoring and Observability
# ============================================================================

# OpenTelemetry Configuration (if enabled)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=jotp-app

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# CI/CD Configuration
# ============================================================================

# Git Configuration
GIT_BRANCH=claude/setup-redis-postgres-maven-Gyuwi

# Build Status
BUILD_ID=local-build
BUILD_TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/Disable Features
ENABLE_REDIS=true
ENABLE_POSTGRES=true
ENABLE_MAVEN_PROXY=true
ENABLE_OBSERVABILITY=false

# ============================================================================
# Security Configuration
# ============================================================================

# Note: These should be overridden in production!
# Use environment files or secret management for sensitive data

# Database Credentials
DB_ROOT_PASSWORD=root_secret

# API Keys
API_KEY_SECRET=change_me_in_production

# OAuth/Authentication
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ============================================================================
# End of Configuration
# ============================================================================
