# Environment Variables Template for Universal Act Testing
# =====================================================
# Copy this file to .env and fill in your actual values
# For development/testing, you can use dummy values

# === Build Configuration ===
# Edit these for your project
JAVA_VERSION=17                          # Your Java version
MAVEN_VERSION=3.8.6                      # Your Maven version
BUILD_PARALLEL=-T1C                     # Parallel build threads
SKIP_TESTS=false                        # Skip tests if true

# === Testing Configuration ===
TEST_PROFILES=test,integration          # Maven test profiles
TEST_JAVA_OPTS=--enable-preview         # Java options for tests
COVERAGE_ENABLED=false                   # Enable JaCoCo coverage

# === Project Configuration ===
PROJECT_NAME=your-project              # Project name
PROJECT_VERSION=1.0.0                    # Project version
GROUP_ID=com.example                    # Maven group ID
ARTIFACT_ID=your-artifact               # Maven artifact ID

# === Environment Flags ===
SKIP_DEPLOY=true                        # Skip deployments in testing
DRY_RUN=true                            # Use dry-run mode
CI_ENABLED=true                        # Enable CI mode
VERBOSE_LOGGING=false                   # Enable verbose logging

# === Feature Flags ===
ENABLE_SECURITY_TESTS=true              # Run security tests
ENABLE_PERFORMANCE_TESTS=true           # Run performance tests
ENABLE_INTEGRATION_TESTS=true           # Run integration tests
ENABLE_SMOKE_TESTS=true                 # Run smoke tests

# === Platform Configuration ===
OS=linux                               # Operating system
ARCH=x86_64                            # Architecture
DOCKER_PLATFORM=linux/amd64            # Docker platform

# === Timeouts ===
BUILD_TIMEOUT=30m                      # Build timeout
TEST_TIMEOUT=20m                       # Test timeout
DEPLOY_TIMEOUT=10m                     # Deployment timeout

# === Paths ===
WORKSPACE_DIR=/workspace               # Workspace directory
CACHE_DIR=/tmp/cache                   # Cache directory
LOGS_DIR=logs                          # Logs directory