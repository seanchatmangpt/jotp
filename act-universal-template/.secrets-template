# Secrets Template for Universal Act Testing
# ========================================
# Copy this file to .secrets and fill in your actual values
# NEVER commit this file to version control!

# === Maven Repository Secrets ===
# For deployments to Maven Central or private repositories
MAVEN_USERNAME=your-maven-username
MAVEN_PASSWORD=your-maven-password

# === GPG Signing Secrets ===
# Required for Maven Central deployments
GPG_PRIVATE_KEY=-----BEGIN PGP PRIVATE KEY BLOCK-----
...paste your full GPG private key here...
-----END PGP PRIVATE KEY BLOCK-----

GPG_PASSPHRASE=your-gpg-passphrase
GPG_KEY_ID=your-gpg-key-id

# === Nexus/Private Repository Secrets ===
NEXUS_USERNAME=your-nexus-username
NEXUS_PASSWORD=your-nexus-password

# === GitHub Secrets ===
GITHUB_TOKEN=your-github-token

# === Environment Secrets ===
# For CI/CD systems
CI_TOKEN=your-ci-token
DEPLOY_TOKEN=your-deploy-token

# === API Tokens ===
# For integrations
DOCKERHUB_TOKEN=your-dockerhub-token
NPM_TOKEN=your-npm-token
PYPI_TOKEN=your-pypi-token

# === Database Secrets ===
# For integration tests
DB_HOST=your-db-host
DB_PORT=your-db-port
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_URL=jdbc:mysql://your-db-host:3306/your_database

# === Cloud Provider Secrets ===
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1

# === Service Account Keys ===
# For GCP/Azure
GOOGLE_APPLICATION_CREDENTIALS='{"type": "service_account", ...}'
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET=your-azure-secret

# === Custom Project Secrets ===
# Add your project-specific secrets here
PROJECT_API_KEY=your-project-api-key
PROJECT_SECRET=your-project-secret