{# Modern Cryptography — AES-GCM, ChaCha20-Poly1305, ECDSA/Ed25519 signatures, HKDF/PBKDF2 key derivation, and SecureRandom best practices for Java 26 #}
{# Before: DES/3DES encryption, MD5/SHA-1 hashing, static seeds → After: AES-256-GCM, ChaCha20-Poly1305, SHA-256+, SecureRandom with default provider #}
---
to: "{{ output_dir }}/{{ package | replace(from='.', to='/') }}/{{ name }}.java"
vars:
  name: "ModernCrypto"
  package: "org.acme"
  output_dir: "src/main/java"
  imports: []
  has_aes_gcm: true
  has_chacha20: true
  has_ecdsa: true
  has_ed25519: true
  has_hkdf: true
  has_pbkdf2: true
  javadoc: ""
---
package {{ package }};

{% for import in imports %}
import {{ import }};
{% endfor %}
import java.nio.ByteBuffer;
import java.nio.charset.StandardCharsets;
import java.security.KeyPair;
import java.security.KeyPairGenerator;
import java.security.MessageDigest;
import java.security.SecureRandom;
import java.security.Signature;
import java.security.spec.ECGenParameterSpec;
import java.security.spec.NamedParameterSpec;
import java.util.Arrays;
import java.util.Base64;
import java.util.Objects;

import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import javax.crypto.SecretKeyFactory;
import javax.crypto.spec.GCMParameterSpec;
import javax.crypto.spec.IvParameterSpec;
import javax.crypto.spec.PBEKeySpec;
import javax.crypto.spec.SecretKeySpec;

{% if javadoc %}
/**
 * {{ javadoc }}
 */
{% else %}
/**
 * Modern cryptography utilities for Java 26.
 *
 * <h2>Migration guide (Before / After)</h2>
 * <pre>
 * BEFORE (insecure — do NOT use):
 *   Cipher.getInstance("DES/ECB/PKCS5Padding")     → weak 56-bit key, ECB mode
 *   MessageDigest.getInstance("MD5")                → collision-vulnerable
 *   new SecureRandom(fixedSeed)                     → predictable output
 *   Cipher.getInstance("DESede/CBC/PKCS5Padding")   → 3DES is deprecated
 *
 * AFTER (secure — use these):
 *   Cipher.getInstance("AES/GCM/NoPadding")         → 256-bit AEAD
 *   Cipher.getInstance("ChaCha20-Poly1305")          → modern AEAD
 *   MessageDigest.getInstance("SHA-256")             → collision-resistant
 *   SecureRandom.getInstanceStrong()                 → OS-seeded CSPRNG
 *   Ed25519 / ECDSA (secp256r1)                      → modern signatures
 * </pre>
 */
{% endif %}
public final class {{ name }} {

    private static final int AES_KEY_SIZE = 256;
    private static final int GCM_IV_LENGTH = 12;
    private static final int GCM_TAG_LENGTH = 128;
    private static final int CHACHA20_NONCE_LENGTH = 12;
    private static final int PBKDF2_ITERATIONS = 600_000;
    private static final int PBKDF2_KEY_LENGTH = 256;
    private static final int SALT_LENGTH = 32;

    /** Thread-safe CSPRNG — always use the platform default (never seed manually). */
    private static final SecureRandom SECURE_RANDOM = new SecureRandom();

    private {{ name }}() {
        // utility class
    }

    // ── SecureRandom best practices ──────────────────────────────────────

    /**
     * Generates cryptographically strong random bytes.
     *
     * <p>Uses the platform default {@link SecureRandom}, which is
     * self-seeding and thread-safe. Never construct with a fixed seed.
     */
    public static byte[] randomBytes(int length) {
        if (length <= 0) {
            throw new IllegalArgumentException("length must be positive");
        }
        var bytes = new byte[length];
        SECURE_RANDOM.nextBytes(bytes);
        return bytes;
    }

    /**
     * Generates a URL-safe Base64 token of the given byte length.
     */
    public static String secureToken(int byteLength) {
        return Base64.getUrlEncoder().withoutPadding().encodeToString(randomBytes(byteLength));
    }
{% if has_aes_gcm %}

    // ── AES-256-GCM (authenticated encryption) ──────────────────────────
    // BEFORE: Cipher.getInstance("DES/ECB/PKCS5Padding") — weak, unauthenticated
    // AFTER:  Cipher.getInstance("AES/GCM/NoPadding") — 256-bit AEAD

    /**
     * Generates a new AES-256 key.
     */
    public static SecretKey generateAesKey() {
        try {
            var keyGen = KeyGenerator.getInstance("AES");
            keyGen.init(AES_KEY_SIZE, SECURE_RANDOM);
            return keyGen.generateKey();
        } catch (Exception e) {
            throw new CryptoException("Failed to generate AES key", e);
        }
    }

    /**
     * Encrypts plaintext using AES-256-GCM.
     *
     * <p>Returns: {@code IV (12 bytes) || ciphertext || GCM tag (16 bytes)}.
     *
     * @param plaintext data to encrypt
     * @param key       AES-256 key
     * @param aad       additional authenticated data (may be {@code null})
     * @return combined IV + ciphertext + tag
     */
    public static byte[] aesGcmEncrypt(byte[] plaintext, SecretKey key, byte[] aad) {
        Objects.requireNonNull(plaintext, "plaintext must not be null");
        Objects.requireNonNull(key, "key must not be null");
        try {
            byte[] iv = randomBytes(GCM_IV_LENGTH);
            var cipher = Cipher.getInstance("AES/GCM/NoPadding");
            cipher.init(Cipher.ENCRYPT_MODE, key, new GCMParameterSpec(GCM_TAG_LENGTH, iv));
            if (aad != null) {
                cipher.updateAAD(aad);
            }
            byte[] ciphertext = cipher.doFinal(plaintext);

            return ByteBuffer.allocate(iv.length + ciphertext.length)
                    .put(iv)
                    .put(ciphertext)
                    .array();
        } catch (Exception e) {
            throw new CryptoException("AES-GCM encryption failed", e);
        }
    }

    /**
     * Decrypts AES-256-GCM ciphertext produced by {@link #aesGcmEncrypt}.
     */
    public static byte[] aesGcmDecrypt(byte[] combined, SecretKey key, byte[] aad) {
        Objects.requireNonNull(combined, "combined must not be null");
        Objects.requireNonNull(key, "key must not be null");
        try {
            var buf = ByteBuffer.wrap(combined);
            byte[] iv = new byte[GCM_IV_LENGTH];
            buf.get(iv);
            byte[] ciphertext = new byte[buf.remaining()];
            buf.get(ciphertext);

            var cipher = Cipher.getInstance("AES/GCM/NoPadding");
            cipher.init(Cipher.DECRYPT_MODE, key, new GCMParameterSpec(GCM_TAG_LENGTH, iv));
            if (aad != null) {
                cipher.updateAAD(aad);
            }
            return cipher.doFinal(ciphertext);
        } catch (Exception e) {
            throw new CryptoException("AES-GCM decryption failed", e);
        }
    }
{% endif %}
{% if has_chacha20 %}

    // ── ChaCha20-Poly1305 (authenticated encryption) ─────────────────────
    // Modern alternative to AES-GCM, resistant to timing attacks without
    // hardware AES-NI support.

    /**
     * Generates a new ChaCha20 256-bit key.
     */
    public static SecretKey generateChaCha20Key() {
        byte[] keyBytes = randomBytes(32);
        return new SecretKeySpec(keyBytes, "ChaCha20");
    }

    /**
     * Encrypts plaintext using ChaCha20-Poly1305.
     *
     * <p>Returns: {@code nonce (12 bytes) || ciphertext || Poly1305 tag}.
     */
    public static byte[] chaCha20Encrypt(byte[] plaintext, SecretKey key, byte[] aad) {
        Objects.requireNonNull(plaintext, "plaintext must not be null");
        Objects.requireNonNull(key, "key must not be null");
        try {
            byte[] nonce = randomBytes(CHACHA20_NONCE_LENGTH);
            var cipher = Cipher.getInstance("ChaCha20-Poly1305");
            cipher.init(Cipher.ENCRYPT_MODE, key, new IvParameterSpec(nonce));
            if (aad != null) {
                cipher.updateAAD(aad);
            }
            byte[] ciphertext = cipher.doFinal(plaintext);

            return ByteBuffer.allocate(nonce.length + ciphertext.length)
                    .put(nonce)
                    .put(ciphertext)
                    .array();
        } catch (Exception e) {
            throw new CryptoException("ChaCha20-Poly1305 encryption failed", e);
        }
    }

    /**
     * Decrypts ChaCha20-Poly1305 ciphertext produced by {@link #chaCha20Encrypt}.
     */
    public static byte[] chaCha20Decrypt(byte[] combined, SecretKey key, byte[] aad) {
        Objects.requireNonNull(combined, "combined must not be null");
        Objects.requireNonNull(key, "key must not be null");
        try {
            var buf = ByteBuffer.wrap(combined);
            byte[] nonce = new byte[CHACHA20_NONCE_LENGTH];
            buf.get(nonce);
            byte[] ciphertext = new byte[buf.remaining()];
            buf.get(ciphertext);

            var cipher = Cipher.getInstance("ChaCha20-Poly1305");
            cipher.init(Cipher.DECRYPT_MODE, key, new IvParameterSpec(nonce));
            if (aad != null) {
                cipher.updateAAD(aad);
            }
            return cipher.doFinal(ciphertext);
        } catch (Exception e) {
            throw new CryptoException("ChaCha20-Poly1305 decryption failed", e);
        }
    }
{% endif %}
{% if has_ecdsa %}

    // ── ECDSA (secp256r1) signatures ─────────────────────────────────────
    // BEFORE: RSA-1024 — key too short for modern security
    // AFTER:  ECDSA P-256 — 128-bit security with compact keys

    /**
     * Generates an ECDSA key pair using the secp256r1 (P-256) curve.
     */
    public static KeyPair generateEcdsaKeyPair() {
        try {
            var keyGen = KeyPairGenerator.getInstance("EC");
            keyGen.initialize(new ECGenParameterSpec("secp256r1"), SECURE_RANDOM);
            return keyGen.generateKeyPair();
        } catch (Exception e) {
            throw new CryptoException("ECDSA key pair generation failed", e);
        }
    }

    /**
     * Signs data using ECDSA with SHA-256.
     */
    public static byte[] ecdsaSign(byte[] data, java.security.PrivateKey privateKey) {
        Objects.requireNonNull(data, "data must not be null");
        Objects.requireNonNull(privateKey, "privateKey must not be null");
        try {
            var sig = Signature.getInstance("SHA256withECDSA");
            sig.initSign(privateKey, SECURE_RANDOM);
            sig.update(data);
            return sig.sign();
        } catch (Exception e) {
            throw new CryptoException("ECDSA signing failed", e);
        }
    }

    /**
     * Verifies an ECDSA signature.
     */
    public static boolean ecdsaVerify(
            byte[] data, byte[] signature, java.security.PublicKey publicKey) {
        Objects.requireNonNull(data, "data must not be null");
        Objects.requireNonNull(signature, "signature must not be null");
        Objects.requireNonNull(publicKey, "publicKey must not be null");
        try {
            var sig = Signature.getInstance("SHA256withECDSA");
            sig.initVerify(publicKey);
            sig.update(data);
            return sig.verify(signature);
        } catch (Exception e) {
            throw new CryptoException("ECDSA verification failed", e);
        }
    }
{% endif %}
{% if has_ed25519 %}

    // ── Ed25519 signatures ───────────────────────────────────────────────
    // Edwards-curve Digital Signature Algorithm: compact 64-byte signatures,
    // 128-bit security, immune to timing side-channel attacks.

    /**
     * Generates an Ed25519 key pair.
     */
    public static KeyPair generateEd25519KeyPair() {
        try {
            var keyGen = KeyPairGenerator.getInstance("Ed25519");
            keyGen.initialize(NamedParameterSpec.ED25519, SECURE_RANDOM);
            return keyGen.generateKeyPair();
        } catch (Exception e) {
            throw new CryptoException("Ed25519 key pair generation failed", e);
        }
    }

    /**
     * Signs data using Ed25519.
     */
    public static byte[] ed25519Sign(byte[] data, java.security.PrivateKey privateKey) {
        Objects.requireNonNull(data, "data must not be null");
        Objects.requireNonNull(privateKey, "privateKey must not be null");
        try {
            var sig = Signature.getInstance("Ed25519");
            sig.initSign(privateKey);
            sig.update(data);
            return sig.sign();
        } catch (Exception e) {
            throw new CryptoException("Ed25519 signing failed", e);
        }
    }

    /**
     * Verifies an Ed25519 signature.
     */
    public static boolean ed25519Verify(
            byte[] data, byte[] signature, java.security.PublicKey publicKey) {
        Objects.requireNonNull(data, "data must not be null");
        Objects.requireNonNull(signature, "signature must not be null");
        Objects.requireNonNull(publicKey, "publicKey must not be null");
        try {
            var sig = Signature.getInstance("Ed25519");
            sig.initVerify(publicKey);
            sig.update(data);
            return sig.verify(signature);
        } catch (Exception e) {
            throw new CryptoException("Ed25519 verification failed", e);
        }
    }
{% endif %}
{% if has_pbkdf2 %}

    // ── PBKDF2 key derivation (password hashing) ─────────────────────────
    // BEFORE: MD5(password) or SHA-1(password) — no salt, no stretching
    // AFTER:  PBKDF2-HMAC-SHA256 with 600k iterations and 32-byte salt

    /**
     * Derives a key from a password using PBKDF2-HMAC-SHA256.
     *
     * <p>Returns: {@code salt (32 bytes) || derived key (32 bytes)}.
     *
     * @param password the user password
     * @return combined salt + derived key
     */
    public static byte[] pbkdf2DeriveKey(char[] password) {
        Objects.requireNonNull(password, "password must not be null");
        try {
            byte[] salt = randomBytes(SALT_LENGTH);
            var spec = new PBEKeySpec(password, salt, PBKDF2_ITERATIONS, PBKDF2_KEY_LENGTH);
            var factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            byte[] derivedKey = factory.generateSecret(spec).getEncoded();
            spec.clearPassword();

            return ByteBuffer.allocate(salt.length + derivedKey.length)
                    .put(salt)
                    .put(derivedKey)
                    .array();
        } catch (Exception e) {
            throw new CryptoException("PBKDF2 key derivation failed", e);
        }
    }

    /**
     * Verifies a password against a PBKDF2-derived key produced by {@link #pbkdf2DeriveKey}.
     */
    public static boolean pbkdf2Verify(char[] password, byte[] combined) {
        Objects.requireNonNull(password, "password must not be null");
        Objects.requireNonNull(combined, "combined must not be null");
        try {
            var buf = ByteBuffer.wrap(combined);
            byte[] salt = new byte[SALT_LENGTH];
            buf.get(salt);
            byte[] storedKey = new byte[buf.remaining()];
            buf.get(storedKey);

            var spec = new PBEKeySpec(password, salt, PBKDF2_ITERATIONS, PBKDF2_KEY_LENGTH);
            var factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            byte[] derivedKey = factory.generateSecret(spec).getEncoded();
            spec.clearPassword();

            return MessageDigest.isEqual(storedKey, derivedKey);
        } catch (Exception e) {
            throw new CryptoException("PBKDF2 verification failed", e);
        }
    }
{% endif %}
{% if has_hkdf %}

    // ── HKDF key derivation (extract-then-expand) ────────────────────────
    // For deriving subkeys from a master key or converting non-uniform
    // random material into uniform keys.

    /**
     * Derives a key using HKDF-SHA256.
     *
     * @param inputKeyMaterial the input keying material
     * @param salt             optional salt (use {@code null} for default)
     * @param info             context and application specific information
     * @param outputLength     desired output key length in bytes
     * @return derived key bytes
     */
    public static byte[] hkdfDerive(
            byte[] inputKeyMaterial, byte[] salt, byte[] info, int outputLength) {
        Objects.requireNonNull(inputKeyMaterial, "inputKeyMaterial must not be null");
        if (outputLength <= 0) {
            throw new IllegalArgumentException("outputLength must be positive");
        }
        try {
            // Extract phase: PRK = HMAC-SHA256(salt, IKM)
            var extractMac = javax.crypto.Mac.getInstance("HmacSHA256");
            byte[] effectiveSalt =
                    (salt != null && salt.length > 0) ? salt : new byte[extractMac.getMacLength()];
            extractMac.init(new SecretKeySpec(effectiveSalt, "HmacSHA256"));
            byte[] prk = extractMac.doFinal(inputKeyMaterial);

            // Expand phase: OKM = T(1) || T(2) || ... || T(N)
            var expandMac = javax.crypto.Mac.getInstance("HmacSHA256");
            expandMac.init(new SecretKeySpec(prk, "HmacSHA256"));
            int hashLen = expandMac.getMacLength();
            int n = (outputLength + hashLen - 1) / hashLen;
            var okm = ByteBuffer.allocate(n * hashLen);
            byte[] ti = new byte[0];

            for (int i = 1; i <= n; i++) {
                expandMac.update(ti);
                if (info != null) {
                    expandMac.update(info);
                }
                expandMac.update((byte) i);
                ti = expandMac.doFinal();
                okm.put(ti);
            }

            return Arrays.copyOf(okm.array(), outputLength);
        } catch (Exception e) {
            throw new CryptoException("HKDF key derivation failed", e);
        }
    }
{% endif %}

    // ── Secure hashing ───────────────────────────────────────────────────
    // BEFORE: MessageDigest.getInstance("MD5") — collision attacks known
    // AFTER:  MessageDigest.getInstance("SHA-256") — collision-resistant

    /**
     * Computes SHA-256 hash of the input data.
     */
    public static byte[] sha256(byte[] data) {
        Objects.requireNonNull(data, "data must not be null");
        try {
            return MessageDigest.getInstance("SHA-256").digest(data);
        } catch (Exception e) {
            throw new CryptoException("SHA-256 hashing failed", e);
        }
    }

    /**
     * Computes SHA-256 hash and returns it as a hex string.
     */
    public static String sha256Hex(byte[] data) {
        return java.util.HexFormat.of().formatHex(sha256(data));
    }

    // ── Utility: constant-time comparison ────────────────────────────────

    /**
     * Constant-time byte array comparison to prevent timing attacks.
     */
    public static boolean constantTimeEquals(byte[] a, byte[] b) {
        return MessageDigest.isEqual(a, b);
    }

    /**
     * Encodes bytes as URL-safe Base64 (no padding).
     */
    public static String toBase64Url(byte[] data) {
        return Base64.getUrlEncoder().withoutPadding().encodeToString(data);
    }

    /**
     * Decodes URL-safe Base64 string.
     */
    public static byte[] fromBase64Url(String encoded) {
        return Base64.getUrlDecoder().decode(encoded);
    }

    // ── Exception type ───────────────────────────────────────────────────

    /**
     * Wraps cryptographic operation failures.
     */
    public static final class CryptoException extends RuntimeException {

        public CryptoException(String message, Throwable cause) {
            super(message, cause);
        }
    }
}
