{# Modern HttpClient (Java 11+) with sync and async HTTP methods, JSON body handling,
   and CompletableFuture patterns. Replaces legacy HttpURLConnection usage. #}
---
to: "{{ output_dir }}/{{ package | replace(from='.', to='/') }}/{{ name }}.java"
vars:
  name: "HttpClientExample"
  package: "org.acme"
  output_dir: "src/main/java"
  base_url: "https://api.example.com"
---
package {{ package }};

import java.io.IOException;
import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.time.Duration;
import java.util.List;
import java.util.Map;
import java.util.concurrent.CompletableFuture;
import java.util.concurrent.Executor;
import java.util.concurrent.Executors;

/**
 * Modern {@link HttpClient} usage (Java 11+).
 *
 * <h2>Before — HttpURLConnection</h2>
 * <pre>{@code
 * // GET request with HttpURLConnection
 * URL url = new URL("https://api.example.com/users/1");
 * HttpURLConnection conn = (HttpURLConnection) url.openConnection();
 * conn.setRequestMethod("GET");
 * conn.setRequestProperty("Accept", "application/json");
 * conn.setConnectTimeout(5000);
 * conn.setReadTimeout(5000);
 *
 * int status = conn.getResponseCode();
 * if (status == 200) {
 *     try (BufferedReader br = new BufferedReader(
 *             new InputStreamReader(conn.getInputStream(), "UTF-8"))) {
 *         StringBuilder sb = new StringBuilder();
 *         String line;
 *         while ((line = br.readLine()) != null) {
 *             sb.append(line);
 *         }
 *         String body = sb.toString();
 *     }
 * }
 * conn.disconnect();
 *
 * // POST request — even more boilerplate
 * HttpURLConnection post = (HttpURLConnection) new URL("https://api.example.com/users").openConnection();
 * post.setRequestMethod("POST");
 * post.setDoOutput(true);
 * post.setRequestProperty("Content-Type", "application/json");
 * try (OutputStream os = post.getOutputStream()) {
 *     os.write("{\"name\":\"Alice\"}".getBytes("UTF-8"));
 * }
 * int postStatus = post.getResponseCode();
 * post.disconnect();
 *
 * // Async? Wrap everything in a thread manually...
 * }</pre>
 *
 * <h2>After — HttpClient</h2>
 * <pre>{@code
 * var api = new HttpClientExample("https://api.example.com");
 *
 * // Synchronous
 * String user = api.get("/users/1");
 * String created = api.post("/users", "{\"name\":\"Alice\"}");
 *
 * // Asynchronous with CompletableFuture
 * api.getAsync("/users/1")
 *    .thenApply(HttpResponse::body)
 *    .thenAccept(System.out::println);
 *
 * // Fan-out: concurrent requests
 * var users = api.getAll(List.of("/users/1", "/users/2", "/users/3"));
 * }</pre>
 */
public final class {{ name }} {

    private static final Duration DEFAULT_TIMEOUT = Duration.ofSeconds(30);
    private static final String JSON = "application/json";

    private final HttpClient client;
    private final String baseUrl;

    /**
     * Creates an HTTP helper targeting the given base URL.
     *
     * @param baseUrl the API base URL (e.g., {@code "{{ base_url }}"})
     */
    public {{ name }}(String baseUrl) {
        this(baseUrl, Executors.newVirtualThreadPerTaskExecutor());
    }

    /**
     * Creates an HTTP helper with a custom executor for async operations.
     *
     * @param baseUrl  the API base URL
     * @param executor the executor for async requests
     */
    public {{ name }}(String baseUrl, Executor executor) {
        this.baseUrl = baseUrl.endsWith("/") ? baseUrl.substring(0, baseUrl.length() - 1) : baseUrl;
        this.client =
                HttpClient.newBuilder()
                        .connectTimeout(DEFAULT_TIMEOUT)
                        .followRedirects(HttpClient.Redirect.NORMAL)
                        .executor(executor)
                        .build();
    }

    // -------------------------------------------------------------------------
    // Synchronous methods
    // -------------------------------------------------------------------------

    /**
     * Performs a synchronous GET request.
     *
     * @param path the path relative to the base URL
     * @return the response body as a string
     * @throws IOException          if an I/O error occurs
     * @throws InterruptedException if the thread is interrupted
     */
    public String get(String path) throws IOException, InterruptedException {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .GET()
                        .build();

        HttpResponse<String> response =
                client.send(request, HttpResponse.BodyHandlers.ofString());
        return requireOk(response).body();
    }

    /**
     * Performs a synchronous POST request with a JSON body.
     *
     * @param path    the path relative to the base URL
     * @param jsonBody the JSON request body
     * @return the response body as a string
     * @throws IOException          if an I/O error occurs
     * @throws InterruptedException if the thread is interrupted
     */
    public String post(String path, String jsonBody) throws IOException, InterruptedException {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Content-Type", JSON)
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .POST(HttpRequest.BodyPublishers.ofString(jsonBody))
                        .build();

        HttpResponse<String> response =
                client.send(request, HttpResponse.BodyHandlers.ofString());
        return requireOk(response).body();
    }

    /**
     * Performs a synchronous PUT request with a JSON body.
     *
     * @param path     the path relative to the base URL
     * @param jsonBody the JSON request body
     * @return the response body as a string
     * @throws IOException          if an I/O error occurs
     * @throws InterruptedException if the thread is interrupted
     */
    public String put(String path, String jsonBody) throws IOException, InterruptedException {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Content-Type", JSON)
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .PUT(HttpRequest.BodyPublishers.ofString(jsonBody))
                        .build();

        HttpResponse<String> response =
                client.send(request, HttpResponse.BodyHandlers.ofString());
        return requireOk(response).body();
    }

    /**
     * Performs a synchronous DELETE request.
     *
     * @param path the path relative to the base URL
     * @return the response body as a string
     * @throws IOException          if an I/O error occurs
     * @throws InterruptedException if the thread is interrupted
     */
    public String delete(String path) throws IOException, InterruptedException {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .DELETE()
                        .build();

        HttpResponse<String> response =
                client.send(request, HttpResponse.BodyHandlers.ofString());
        return requireOk(response).body();
    }

    // -------------------------------------------------------------------------
    // Asynchronous methods — CompletableFuture patterns
    // -------------------------------------------------------------------------

    /**
     * Performs an asynchronous GET request.
     *
     * @param path the path relative to the base URL
     * @return a future completing with the HTTP response
     */
    public CompletableFuture<HttpResponse<String>> getAsync(String path) {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .GET()
                        .build();

        return client.sendAsync(request, HttpResponse.BodyHandlers.ofString());
    }

    /**
     * Performs an asynchronous POST request with a JSON body.
     *
     * @param path     the path relative to the base URL
     * @param jsonBody the JSON request body
     * @return a future completing with the HTTP response
     */
    public CompletableFuture<HttpResponse<String>> postAsync(String path, String jsonBody) {
        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(resolve(path))
                        .header("Content-Type", JSON)
                        .header("Accept", JSON)
                        .timeout(DEFAULT_TIMEOUT)
                        .POST(HttpRequest.BodyPublishers.ofString(jsonBody))
                        .build();

        return client.sendAsync(request, HttpResponse.BodyHandlers.ofString());
    }

    /**
     * Fan-out: performs concurrent GET requests for multiple paths and collects
     * all results.
     *
     * <p>Uses {@link CompletableFuture#allOf} to wait for all requests in parallel.
     *
     * @param paths the paths to request concurrently
     * @return a future completing with a list of response bodies in input order
     */
    public CompletableFuture<List<String>> getAll(List<String> paths) {
        List<CompletableFuture<String>> futures =
                paths.stream()
                        .map(
                                path ->
                                        getAsync(path)
                                                .thenApply(HttpResponse::body))
                        .toList();

        return CompletableFuture.allOf(futures.toArray(CompletableFuture[]::new))
                .thenApply(_ -> futures.stream().map(CompletableFuture::join).toList());
    }

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    private URI resolve(String path) {
        String normalized = path.startsWith("/") ? path : "/" + path;
        return URI.create(baseUrl + normalized);
    }

    private static HttpResponse<String> requireOk(HttpResponse<String> response) {
        int status = response.statusCode();
        if (status >= 200 && status < 300) {
            return response;
        }
        throw new HttpException(status, response.body());
    }

    /** Exception thrown when the server returns a non-2xx status code. */
    public static final class HttpException extends RuntimeException {

        private final int statusCode;
        private final String responseBody;

        public HttpException(int statusCode, String responseBody) {
            super("HTTP %d: %s".formatted(statusCode, responseBody));
            this.statusCode = statusCode;
            this.responseBody = responseBody;
        }

        public int statusCode() {
            return statusCode;
        }

        public String responseBody() {
            return responseBody;
        }
    }
}
