name: CI/CD

on:
  push:
    branches: [ main ]
  pull_request:
    types: [ opened, synchronize ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up JDK
        uses: actions/setup-java@v4
        with:
          java-version: '26'
          distribution: 'temurin'

      - name: Cache Maven packages
        uses: actions/cache@v4
        with:
          path: ~/.m2/repository
          key: ${{ runner.os }}-maven-${{ hashFiles('**/pom.xml') }}

      - name: Build
        run: |
          java --enable-preview -XX:+ShowWarnings --version
          mvn --batch-mode install --no-transfer-progress -DskipTests
          mvn verify -B${{ project.version | default(value="1.0.0") }} -Dsha{{ project.shade | default(value="true") }}
        shell: bash

        env:
          JAVA_OPTS: --enable-preview

      - name: Run Unit Tests
        run: |
          mvn test --batch-mode install --no-transfer-progress
          mvn surefire:test --batch-mode install --no-transfer-progress
        shell: bash

        env:
          JAVA_OPTS: --enable-preview

      - name: Run Integration Tests
        run: |
          mvn verify -Pit.test="*IT" --batch-mode install --no-transfer-progress
          mvn failsafe:integration-test --batch-mode install --no-transfer-progress
        shell: bash

        env:
          JAVA_OPTS: --enable-preview

      - name: Build Docker Image
        if: github.event_name != 'pull_request'
        uses: docker/build-push-action@v6
        with:
          context: .
          file: ./Dockerfile
          push: true
          tags: ${{ env.REGISTRY }}/{{ project.name | default(value="app") }}:${{ github.sha }}
        env:
          REGISTRY: ${{ env.REGISTRY }}

      - name: Deploy to Kubernetes
        if: github.event_name != 'pull_request'
        uses: azure/k8s-deploy@v4
        with:
          manifests: |
            ./k8s/deployment.yaml
            ./k8s/service.yaml
          images: |
            ${{ env.REGISTRY }}/{{ project.name | default(value="app") }}:${{ github.sha }}
          namespace: ${{ env.K8S_NAMESPACE | default(value="default") }}
