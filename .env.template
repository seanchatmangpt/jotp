# Environment variables for Act testing
# Copy this to .env and fill in your actual values

# Java version
JAVA_VERSION=26

# Build flags
MAVEN_OPTS=-Xmx2g -Xms1g -Dmaven.repo.local=${{ github.workspace }}/.m2/repository
SKIP_DEPLOY=true
DRY_RUN=true

# Testing flags
TEST_PROFILES=test,integration
BUILD_PARALLEL=-T1C